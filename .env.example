# ⚠️ 이 파일(.env.example)은 GitHub에 공개됩니다. 여기에 키를 넣지 마세요!
# 실제 키는 같은 폴더의 .env 파일에 넣으세요 (.env는 GitHub에 올라가지 않습니다).
# 이 파일은 "어떤 항목이 필요한지" 보여주는 양식일 뿐입니다.

# ── 텍스트(주제/대본/번역/메타데이터) ──────────────────────────────────
# 아래 둘 중 하나만 있으면 된다. 둘 다 있으면 KIE가 우선한다.

# 권장: KIE 경유 — 같은 Claude 모델을 약 60% 저렴하게. https://kie.ai/api-key
# 발급 후 키별 사용량 상한(hourly/daily/total)을 꼭 걸어두세요.
KIE_API_KEY=

# 대안: Anthropic 직접 호출 — https://console.anthropic.com
ANTHROPIC_API_KEY=

# 선택: 모델 변경 (기본 claude-opus-4-8)
# LLM_MODEL=claude-opus-4-8

# 음성(TTS) — https://studio.typecast.ai/developers 에서 발급
# 없으면 ⚡ 자동화가 음성·자막만 건너뛰고 나머지는 그대로 만듭니다.
TYPECAST_API_KEY=

# 선택: 하루 최대 영상 편수 (기본 10). 자동화 반복 실행으로 인한 과금을 막는 안전장치.
# DAILY_VIDEO_LIMIT=10

# 선택: 결과물 저장 폴더 (기본 바탕화면\일본쇼츠)
# OUTPUT_DIR=

# 선택: 서버 포트 (기본 3000)
PORT=3000
