# ── 텍스트(주제/대본/번역/메타데이터) ──────────────────────────────────
# 아래 둘 중 하나만 있으면 된다. 둘 다 있으면 KIE가 우선한다.

# 권장: KIE 경유 — 같은 Claude 모델을 약 60% 저렴하게. https://kie.ai/api-key
# 발급 후 키별 사용량 상한(hourly/daily/total)을 꼭 걸어두세요.
KIE_API_KEY=

# 대안: Anthropic 직접 호출 — https://console.anthropic.com
ANTHROPIC_API_KEY=

# 선택: 모델 변경 (기본 claude-opus-4-8)
# LLM_MODEL=claude-opus-4-8

# 이미지 생성용 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=AIza...

# 선택: 서버 포트 (기본 3000)
PORT=3000
